  "description": "AI Team Skills CLI - Multi-agent development team system",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "aiteam": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
